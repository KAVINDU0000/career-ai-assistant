# Copy this file to .env and fill in real values. Never commit .env itself.

# Required: your OpenAI API key
OPENAI_API_KEY=sk-your-key-here

# Optional: model to use for all agents (default: gpt-4o)
OPENAI_MODEL_NAME=gpt-4o

# Optional: sampling temperature for agent reasoning (default: 0.3)
LLM_TEMPERATURE=0.3

# Optional: max resume upload size in MB (default: 10)
MAX_RESUME_FILE_MB=10

# Optional: output filename for the generated report (default: career_report.md)
REPORT_FILENAME=career_report.md
